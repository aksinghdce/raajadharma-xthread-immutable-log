# X (Twitter) API Credentials — Required only for automated posting
# Leave blank to use manual copy-paste fallback mode
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# The fixed community thread URL (never change this)
COMMUNITY_URL=https://x.com/i/communities/1981771124343283876

# The tweet ID of the first pinned post in the community thread
# Set this after running: raajadharma-log init-thread
PINNED_THREAD_TWEET_ID=

# Optional: IPFS gateway for media hashes
IPFS_GATEWAY=https://ipfs.io/ipfs/
